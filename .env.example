SECRET_KEY=change-this-to-a-random-string
DATABASE_URL=sqlite:///rentmate.db

# LLM (Anthropic API) — leave blank to always use the rule-based fallback scorer
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Email (Gmail SMTP example — use an App Password, not your real password)
# Leave MAIL_USERNAME blank to log emails to console instead of sending them
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
